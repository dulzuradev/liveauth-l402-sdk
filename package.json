{
  "name": "@liveauth-labs/l402-sdk",
  "version": "0.1.0",
  "description": "Lightning-native L402 invoice, token, and HTTP 402 helpers for LiveAuth",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liveauth-labs/liveauth-l402-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/liveauth-labs/liveauth-l402-sdk/issues"
  },
  "homepage": "https://github.com/liveauth-labs/liveauth-l402-sdk#readme",
  "keywords": [
    "l402",
    "lightning",
    "bitcoin",
    "payments",
    "liveauth",
    "ai-agents"
  ],
  "author": "LiveAuth",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
